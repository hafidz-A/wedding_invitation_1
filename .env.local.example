# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored — never commit real keys.

# ─── Supabase ─────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon / public key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — SERVER ONLY, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App config ───────────────────────────────────────────────────────────
# Base URL of the deployed site (used for OG tags, redirects, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret used to sign admin session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-random-32-byte-hex-string

# ─── Forgot-password emails (Resend) ─────────────────────────────────────
# Get from: resend.com → API Keys → Create API Key
# Free tier: 100 emails/day, 3000/month.
# When not set, /api/auth/forgot-password returns the reset URL in the
# response (dev mode) instead of sending an email — useful for local dev.
RESEND_API_KEY=

# Sender address. The default works without domain verification but is
# obviously not branded. To use your own domain (recommended for prod):
#   1. Resend dashboard → Domains → add yours → set DNS records.
#   2. Change this to e.g. "reset@kawinin.id".
RESEND_FROM=onboarding@resend.dev
