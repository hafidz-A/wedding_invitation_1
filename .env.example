# Copy this file to `.env.local` and fill in real values.
# .env.local is gitignored — never commit real keys.

# ─── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App config ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# ─── Email (Resend) ───────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ─── Guests table PII encryption ─────────────────────────────────────────
# AES-256-GCM key for encrypting guest names, phone numbers, and notes.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# BACK THIS UP OUT-OF-BAND. Losing this key permanently bricks every encrypted row.
GUESTS_ENCRYPTION_KEY=
